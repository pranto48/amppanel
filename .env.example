# ============================================
# AMP Panel - Environment Variables
# ============================================
# Copy this file to .env and update the values
# cp .env.example .env
# ============================================

# --- Domain Configuration ---
AMP_DOMAIN=localhost
AMP_ADMIN_EMAIL=admin_amp@localhost

# --- Port Configuration ---
# Change these if default ports are already in use
AMP_HTTP_PORT=8880
AMP_HTTPS_PORT=8443

# --- Database (PostgreSQL) ---
DB_PASSWORD=amp_secure_2024

# --- Supabase Configuration ---
# These are provided by your AMP Panel license or Lovable Cloud
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# --- Resource Limits (Optional) ---
# CPU limits (number of cores, e.g., 0.5, 1.0, 2.0)
AMP_PANEL_CPU_LIMIT=1.0
POSTGRES_CPU_LIMIT=1.0
REDIS_CPU_LIMIT=0.5
NGINX_CPU_LIMIT=0.5

# Memory limits (e.g., 256M, 512M, 1G)
AMP_PANEL_MEMORY_LIMIT=512M
POSTGRES_MEMORY_LIMIT=1G
REDIS_MEMORY_LIMIT=256M
NGINX_MEMORY_LIMIT=128M

# --- Email Notifications (Optional) ---
# Get your API key from https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx

# --- GitHub Repository (Optional) ---
# Used for linking version hash to commit page
# Example: https://github.com/username/amp-panel
VITE_GITHUB_REPO_URL=
